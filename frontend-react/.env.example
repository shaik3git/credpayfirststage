# Backend base URLs - ONLY for local development with `npm run dev`, where
# the Vite dev server (:5173) must call the backends directly cross-origin.
#
# Copy this file to `.env` to enable local dev against services running on
# your machine:
#   cp .env.example .env
#
# Do NOT create a `.env` file for Docker builds or CI/CD. The Dockerfile
# does not copy `.env` files into the build (see .dockerignore), so Docker
# and AKS images always fall back to relative URLs ('') in api.js, which is
# what allows the same image to work behind any Ingress IP/hostname.
VITE_USER_API_URL=http://localhost:8080
VITE_PAYMENT_API_URL=http://localhost:8000
