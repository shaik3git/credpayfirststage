# =====================================================================
# Terraform
# =====================================================================
# Local provider plugins / modules cache
.terraform/
.terraform.lock.hcl

# State files (may contain secrets in plaintext, e.g. DB passwords)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Variable files with real values - keep only *.tfvars.example
# EXCEPTION: terraform/terraform.tfvars is intentionally committed for this
# capstone project (see terraform/terraform.tfvars's own header comment).
*.tfvars
*.tfvars.json
!*.tfvars.example
!terraform/terraform.tfvars

# Saved plans
*.tfplan

# CLI config that may hold credentials
.terraformrc
terraform.rc
